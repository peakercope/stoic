{
  "name": "stoic",
  "type": "module",
  "version": "0.0.1",
  "description": "Minimal and powerful React state manager. Tiny, intuitive, and fully TypeScript-ready.",
  "author": "peakercope <peakercope@gmail.com> (https://github.com/peakercope)",
  "license": "MIT",
  "keywords": [
    "react",
    "state",
    "state-management",
    "store",
    "derived-state",
    "typescript"
  ],
  "homepage": "https://github.com/peakercope/stoic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peakercope/stoic.git",
    "directory": "packages/stoic"
  },
  "bugs": {
    "url": "https://github.com/peakercope/stoic/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./plugins": "./dist/plugins.js",
    "./tools": "./dist/tools.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.8.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsdown": "^0.22.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
