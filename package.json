{
  "name": "stoic-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace stoic-store build",
    "dev": "yarn workspace stoic-store dev",
    "play": "yarn workspace playground dev",
    "test": "yarn workspace stoic-store test",
    "typecheck": "yarn workspace stoic-store typecheck && yarn workspace playground typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "^2.31.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.3.5",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.17.0"
}
