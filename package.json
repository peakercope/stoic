{
  "name": "stoic-store",
  "type": "module",
  "version": "0.11.1",
  "description": "Minimal and powerful React state manager. Tiny, intuitive, and fully TypeScript-ready.",
  "author": "peakercope <peakercope@gmail.com> (https://github.com/peakercope)",
  "license": "MIT",
  "keywords": [
    "react",
    "state",
    "state-management",
    "store",
    "derived-state",
    "typescript"
  ],
  "homepage": "https://github.com/peakercope/stoic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peakercope/stoic.git"
  },
  "bugs": {
    "url": "https://github.com/peakercope/stoic/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./plugins": "./dist/plugins.js",
    "./plugins/devtools": "./dist/plugins/devtools.js",
    "./plugins/persist": "./dist/plugins/persist.js",
    "./react": "./dist/react.js",
    "./tools": "./dist/tools.js",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write",
    "lint": "biome ci",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build && changeset publish"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "^2.31.1",
    "@redux-devtools/extension": "^4.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redux": "5.0.1",
    "tsdown": "^0.22.9",
    "typescript": "^6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "packageManager": "yarn@4.17.1"
}
